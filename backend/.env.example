# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sentinelx

# Redis Configuration  
REDIS_URL=redis://localhost:6379

# JWT Configuration - CHANGE THESE IN PRODUCTION!
JWT_ACCESS_SECRET=your-super-secure-jwt-access-secret-change-in-production
JWT_REFRESH_SECRET=your-super-secure-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration - CHANGE THIS IN PRODUCTION!
SESSION_SECRET=your-super-secure-session-secret-change-in-production

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS Configuration (Optional - Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Trust Engine Configuration
ML_CONFIDENCE_THRESHOLD=0.7
TRUST_SCORE_DECAY_RATE=0.1
BEHAVIORAL_ANALYSIS_WINDOW_HOURS=24

# Audit Configuration
BLOCKCHAIN_NETWORK=development
AUDIT_RETENTION_DAYS=365

# Feature Flags
ENABLE_ATTACK_SIMULATOR=true
ENABLE_BLOCKCHAIN_AUDIT=true
ENABLE_ML_TRUST_ENGINE=true
ENABLE_DEVICE_FINGERPRINTING=true