# Server
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/sentinelx
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# WebAuthn
RP_ID=localhost
RP_NAME=SentinelX
ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Security
BCRYPT_ROUNDS=12
SALT_ROUNDS=16
SESSION_TIMEOUT=3600

# Trust Engine
TRUST_ENGINE_URL=http://localhost:8000
BEHAVIORAL_AI_ENABLED=true
CONTEXT_ENGINE_ENABLED=true

# RSA Keys for signing (generate with: openssl genrsa -out private.pem 2048)
PRIVATE_KEY=your-rsa-private-key-pem
PUBLIC_KEY=your-rsa-public-key-pem

# Feature Flags
FEATURE_ATTACK_SIMULATOR=true
FEATURE_BREAK_GLASS=true
FEATURE_OFFLINE_AUTH=true
FEATURE_ZERO_KNOWLEDGE=true
